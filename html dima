<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>About Me</title>

    <style>

        body {
            margin: 0;
            padding: 0;
            background: linear-gradient(to right, #1e3c72, #2a5298);
            font-family: Arial, sans-serif;
            text-align: center;
            color: white;
        }

        h1 {
            font-size: 50px;
            color: #ffcc00;
            margin-top: 20px;
        }

        h2 {
            color: #ffd966;
        }

        p {
            font-size: 18px;
            line-height: 1.6;
        }

        ul {
            list-style-type: square;
            text-align: left;
            display: inline-block;
            font-size: 18px;
        }

        img {
            border: 4px solid white;
        }

        /* CARD STYLE */
        .card {
            background: rgba(255,255,255,0.1);
            backdrop-filter: blur(10px);
            padding: 25px;
            margin: 30px auto;
            width: 80%;
            border-radius: 20px;
            box-shadow: 0px 6px 15px black;
            transition: transform 0.3s ease;
        }

        .card:hover {
            transform: scale(1.03);
        }

        /* NAME HIGHLIGHT */
        .highlight {
            color: #ffcc00;
            font-weight: bold;
        }

        /* PHOTO STYLE */
        .photo {
            width: 250px;
            border-radius: 20px;
            margin: 15px;
            transition: transform 0.3s ease;
        }

        .photo:hover {
            transform: scale(1.08);
        }

        /* BUTTON */
        .btn {
            display: inline-block;
            margin-top: 15px;
            padding: 12px 20px;
            background-color: #ffcc00;
            color: black;
            text-decoration: none;
            border-radius: 10px;
            font-weight: bold;
            transition: 0.3s;
        }

        .btn:hover {
            background-color: white;
            color: #1e3c72;
        }

    </style>
</head>

<body>

